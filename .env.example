# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=seu_token_aqui
ADMIN_TELEGRAM_ID=seu_id_telegram_aqui

# === MERCADO PAGO (PIX) ===
MERCADOPAGO_ACCESS_TOKEN=seu_access_token_aqui
MERCADOPAGO_WEBHOOK_SECRET=

# === FOXBIT (PREFERENCIAL) — exchange brasileira, BRL→USDT ===
# Criar em: foxbit.com.br → Perfil → API → Nova chave (Leitura + Negociação)
FOXBIT_API_KEY=
FOXBIT_API_SECRET=

# === MERCADO BITCOIN (MB) — alternativa ao Foxbit ===
# Obs: requer 2FA ativo pelo app MB antes de criar chave
MB_API_KEY=
MB_API_SECRET=

# === BINANCE (legado) ===
BINANCE_API_KEY=
BINANCE_API_SECRET=

# === TROPIPAY (Entrega MLC automática — opcional) ===
TROPIPAY_CLIENT_ID=
TROPIPAY_CLIENT_SECRET=

# === NOONES P2P (Entrega CUP semi-automática — opcional) ===
NOONES_API_KEY=
NOONES_WEBHOOK_SECRET=

# === SUPABASE ===
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=sua_service_key_aqui

# === BOT CONFIG ===
# true = modo webhook (produção/Railway), false = long polling (desenvolvimento local)
WEBHOOK_MODE=false
# URL pública HTTPS (obrigatório se WEBHOOK_MODE=true)
WEBHOOK_URL=https://seu-dominio.railway.app

# === NEGÓCIO ===
MARGEM_MINIMA_CUP_POR_BRL=5
TAXA_OFERTADA_CUP_POR_BRL=97
LIMITE_MINIMO_BRL=50
LIMITE_MAXIMO_BRL=3000
LIMITE_DIARIO_BRL=3000
LIMITE_MENSAL_BRL=10000
LIMITE_REVISAO_MANUAL_BRL=1500
