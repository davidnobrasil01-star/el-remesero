# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=seu_token_aqui
ADMIN_TELEGRAM_ID=seu_id_telegram_aqui

# === OPENPIX (PIX) ===
OPENPIX_APP_ID=seu_app_id_aqui
OPENPIX_WEBHOOK_SECRET=seu_webhook_secret_aqui

# === BINANCE (Conversão BRL → USDT) ===
BINANCE_API_KEY=sua_api_key_aqui
BINANCE_API_SECRET=seu_api_secret_aqui

# === QVAPAY (Entrega Cuba) ===
QVAPAY_APP_ID=seu_app_id_aqui
QVAPAY_APP_SECRET=seu_app_secret_aqui

# === SUPABASE ===
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=sua_service_key_aqui

# === BOT CONFIG ===
# true = modo webhook (produção), false = long polling (desenvolvimento local)
WEBHOOK_MODE=false
# URL pública HTTPS (obrigatório se WEBHOOK_MODE=true, ex: ngrok ou VPS)
WEBHOOK_URL=https://seu-dominio.com

# === NEGÓCIO ===
# Taxa mínima de CUP por BRL garantida como lucro
MARGEM_MINIMA_CUP_POR_BRL=5
# Taxa ofertada ao cliente (CUP por BRL)
TAXA_OFERTADA_CUP_POR_BRL=97
# Limites de transferência (BRL)
LIMITE_MINIMO_BRL=50
LIMITE_MAXIMO_BRL=3000
LIMITE_DIARIO_BRL=3000
LIMITE_MENSAL_BRL=10000
# Valor acima do qual entra em revisão manual (BRL)
LIMITE_REVISAO_MANUAL_BRL=1500
